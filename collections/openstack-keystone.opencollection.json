{
  "opencollection": "1.0.0",
  "info": {
    "name": "OpenStack Identity (Keystone) API v3",
    "version": "3"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-Auth-Token",
      "value": "{{X-Auth-Token}}",
      "placement": "header"
    }
  },
